# Operating system files
.DS_Store
Thumbs.db
desktop.ini

# Editors and IDEs
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.code-workspace

# Vim / generic editor temp files
*.swp
*.swo
*~

# Logs and temporary files
*.log
*.tmp
*.bak
*.cache

# Environment and local-only configuration
# Keep secrets and machine-specific settings out of Git
.env
.env.*
*.local
config.local.*
secrets.*
*.secret

# Node.js tooling
# Useful if you add Panorama/frontend tooling later
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python tooling
# Useful if you add helper scripts or automation
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/

# Archive files
# Avoid committing exported packages by mistake
*.zip
*.7z
*.rar

# Dota 2 custom game local/temp artifacts
# These are optional ignores for machine-specific junk
content/dota_addons/*/.temp/
game/dota_addons/*/.temp/
content/dota_addons/*/tmp/
game/dota_addons/*/tmp/

# Source maps, if generated by custom Panorama tooling
content/dota_addons/*/panorama/**/*.map
game/dota_addons/*/panorama/**/*.map
